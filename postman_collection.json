{
  "info": {
    "name": "Pramaan Trust OS Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "msmeToken", "value": "" },
    { "key": "buyerToken", "value": "" },
    { "key": "consentId", "value": "" },
    { "key": "reportId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login MSME",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"msme@pramaan.demo\",\"password\":\"password123\"}"
        }
      }
    },
    {
      "name": "Auth - Login Buyer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"buyer@pramaan.demo\",\"password\":\"password123\"}"
        }
      }
    },
    {
      "name": "MSME - Internal Cross-Check",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/business/cross-check"
      }
    },
    {
      "name": "MSME - Generate Business Trust Profile",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/passport/generate"
      }
    },
    {
      "name": "Buyer - Request Consent",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/consent-requests",
        "body": {
          "mode": "raw",
          "raw": "{\"businessGstin\":\"33ABCDE1234F1Z5\",\"requestedFields\":[\"legalBusinessName\",\"gstin\",\"udyamNumber\",\"summary\",\"limitations\"]}"
        }
      }
    },
    {
      "name": "Readiness - List Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/readiness-profiles"
      }
    },
    {
      "name": "Readiness - Evaluate Vendor Onboarding",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/readiness-profiles/vendor-onboarding/evaluate"
      }
    },
    {
      "name": "Reports - List Types",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/report-types"
      }
    },
    {
      "name": "Reports - Generate Business Trust Profile",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{msmeToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/reports/generate",
        "body": { "mode": "raw", "raw": "{\"reportType\":\"BUSINESS_TRUST_PROFILE\"}" }
      }
    },
    {
      "name": "Reports - Generate Vendor Readiness",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{msmeToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/reports/generate",
        "body": { "mode": "raw", "raw": "{\"reportType\":\"VENDOR_ONBOARDING_READINESS\"}" }
      }
    },
    {
      "name": "Reports - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/reports"
      }
    },
    {
      "name": "Reports - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/reports/{{reportId}}"
      }
    },
    {
      "name": "Reports - Revoke",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/reports/{{reportId}}/revoke"
      }
    },
    {
      "name": "Reports - Buyer Forbidden",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
        "url": "{{baseUrl}}/api/reports/{{reportId}}"
      }
    },
    {
      "name": "MSME - Incoming Requests",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/consent-requests?scope=incoming"
      }
    },
    {
      "name": "MSME - Approve Consent",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{msmeToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/consent-requests/{{consentId}}/approve",
        "body": {
          "mode": "raw",
          "raw": "{\"approvedFields\":[\"legalBusinessName\",\"gstin\",\"udyamNumber\",\"summary\"],\"durationDays\":7}"
        }
      }
    },
    {
      "name": "Buyer - Dynamic Trust View",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
        "url": "{{baseUrl}}/api/trust-view/{{consentId}}"
      }
    },
    {
      "name": "MSME - Revoke Consent",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/consent-requests/{{consentId}}/revoke"
      }
    },
    {
      "name": "MSME - Audit Logs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{msmeToken}}" }],
        "url": "{{baseUrl}}/api/audit-logs"
      }
    }
  ]
}
