generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MSME
  BUYER
  BANK
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FLAGGED
}

enum EvidenceStatus {
  SELF_DECLARED
  DOCUMENT_SUBMITTED
  CROSS_CHECKED
  SOURCE_VERIFIED
  REJECTED
  EXPIRED
}

enum ReadinessLevel {
  NOT_READY
  EARLY_STAGE
  PARTIALLY_READY
  MOSTLY_READY
  READY_FOR_REVIEW
  BLOCKED
}

enum DocumentType {
  GST_CERTIFICATE
  UDYAM_CERTIFICATE
  BANK_STATEMENT
}

enum ConsentStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
  EXPIRED
}

enum AuditAction {
  REQUESTED
  APPROVED
  REJECTED
  VIEWED
  REVOKED
  EXPIRED
  PASSPORT_GENERATED
  BUSINESS_VERIFIED
  BUSINESS_PROFILE_CREATED
  BUSINESS_PROFILE_UPDATED
  DOCUMENT_SUBMITTED
  BUSINESS_CROSS_CHECKED
  EVIDENCE_GAP_FOUND
  CONTRADICTION_FOUND
  TRUST_PROFILE_GENERATED
  CONSENT_REQUESTED
  CONSENT_APPROVED
  TRUST_PROFILE_VIEWED
  CONSENT_REVOKED
  READINESS_PROFILE_EVALUATED
  READINESS_PROFILE_BLOCKED
  READINESS_PROFILE_SHARED
}

model User {
  id               String           @id @default(cuid())
  role             UserRole
  name             String
  organizationName String
  email            String           @unique
  passwordHash     String
  createdAt        DateTime         @default(now())
  business         Business?
  consentRequests  ConsentRequest[] @relation("RequesterConsents")
  auditLogs        AuditLog[]        @relation("ActorAuditLogs")
  notifications    Notification[]
}

model Business {
  id                 String             @id @default(cuid())
  userId             String             @unique
  legalName          String?
  gstin              String?            @unique
  udyamNumber        String?
  pan                String?
  address            String?
  turnoverBand       String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  trustStatus        EvidenceStatus     @default(SELF_DECLARED)
  trustSummary       Json?
  lastCrossCheckedAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id])
  documents          Document[]
  passports          Passport[]
  consentRequests    ConsentRequest[]
  auditLogs          AuditLog[]
  readinessEvaluations ReadinessEvaluation[]
}

model Document {
  id           String       @id @default(cuid())
  businessId   String
  docType      DocumentType
  filePath     String
  originalName String
  mimeType     String
  verifiedFlag Boolean      @default(false)
  evidenceStatus EvidenceStatus @default(DOCUMENT_SUBMITTED)
  confidence     Int            @default(0)
  confidenceReason String?
  crossCheckMethod String?
  source          String?
  checkedAt       DateTime?
  expiresAt       DateTime?
  contradictionDetails Json?
  uploadedAt   DateTime     @default(now())
  business     Business     @relation(fields: [businessId], references: [id])
}

model Passport {
  id           String   @id @default(cuid())
  businessId   String
  version      Int
  snapshotJson Json
  generatedAt  DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, version])
}

model ConsentRequest {
  id              String          @id @default(cuid())
  requesterId     String
  businessId      String
  requestedFields Json
  approvedFields  Json?
  status          ConsentStatus   @default(PENDING)
  durationDays    Int?
  approvedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime        @default(now())
  requester       User            @relation("RequesterConsents", fields: [requesterId], references: [id])
  business        Business        @relation(fields: [businessId], references: [id])
  auditLogs       AuditLog[]
  notifications   Notification[]
}

model AuditLog {
  id               String          @id @default(cuid())
  businessId       String
  consentRequestId String?
  actorId          String
  action           AuditAction
  metadata         Json?
  createdAt        DateTime        @default(now())
  business         Business        @relation(fields: [businessId], references: [id])
  consentRequest   ConsentRequest? @relation(fields: [consentRequestId], references: [id])
  actor            User            @relation("ActorAuditLogs", fields: [actorId], references: [id])
}

model Notification {
  id               String          @id @default(cuid())
  userId           String
  message          String
  readFlag         Boolean         @default(false)
  relatedConsentId String?
  createdAt        DateTime        @default(now())
  user             User            @relation(fields: [userId], references: [id])
  relatedConsent   ConsentRequest? @relation(fields: [relatedConsentId], references: [id])
}

model ReadinessEvaluation {
  id             String         @id @default(cuid())
  businessId     String
  profileId      String
  profileVersion String
  score          Int
  level          ReadinessLevel
  blocked        Boolean
  summaryJson    Json
  evaluatedAt    DateTime       @default(now())
  business       Business       @relation(fields: [businessId], references: [id])
}
